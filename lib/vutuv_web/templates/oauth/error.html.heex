<.page_header title={gettext("Authorization failed")} crumbs={[gettext("Authorize")]} />

<div class="card-list">
  <section class="card" id="oauth-error">
    <p class="text-sm text-slate-700 dark:text-slate-200">{error_text(@reason)}</p>
    <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">
      {gettext("Nothing was changed on your account.")}
    </p>
  </section>
</div>
