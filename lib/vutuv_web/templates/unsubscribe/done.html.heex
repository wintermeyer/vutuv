<.page_header title={gettext("Unsubscribe")} />

<div class="card-list">
  <section class="card">
    <p>
      {gettext("Done. @%{slug} will no longer receive %{label}.",
        slug: @user.username,
        label: pref_label(@field)
      )}
    </p>
    <p>{gettext("You can switch this back on in your settings at any time.")}</p>
  </section>
</div>
