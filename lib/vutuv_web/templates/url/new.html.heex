<.page_header crumbs={[
  gettext("Users"),
  {full_name(@user), ~p"/#{@user}"},
  {gettext("Links"), ~p"/#{@user}/links"},
  gettext("New")
]} />

<.card_section>
  <%= render "form_content.html", backlink: ~p"/#{@user}/links", changeset: @changeset, action: ~p"/#{@user}/links" %>
</.card_section>
