<!doctype html>
<html lang={Gettext.get_locale(VutuvWeb.Gettext)}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{error_title(assigns)}</title>
    <meta name="robots" content="noindex" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />
    <%!-- The styling is inlined **on purpose**. An error page is exactly the
    moment the app, the database or the digested asset pipeline may be broken,
    so it must not depend on /assets/app.css (which is why render_errors runs
    with no app layout). This mirrors the .error-page / .button / canvas rules
    from components.css so a rescued 500 looks like the rest of vutuv.de -
    Direction A blue on the slate canvas, system-following dark mode - instead
    of the browser's bare serif default. HEEx treats <style> as raw text, so
    the CSS braces need no escaping. --%>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        min-height: 100vh;
        background: #f1f5f9;
        color: #334155;
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, "Noto Sans", sans-serif;
        -webkit-font-smoothing: antialiased;
        line-height: 1.5;
      }
      .error-shell {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 3rem 1rem;
      }
      .error-shell__brand {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.025em;
        color: #1e3a8a;
        text-decoration: none;
      }
      .error-page {
        width: 100%;
        max-width: 28rem;
        margin: 2rem auto 0;
        padding: 2.5rem 1.5rem;
        text-align: center;
        background: #ffffff;
        border-radius: 1rem;
        box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        outline: 1px solid #e2e8f0;
        outline-offset: -1px;
      }
      .error-page__code {
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
        color: #cbd5e1;
        margin: 0 0 0.75rem;
      }
      .error-page__title {
        font-size: 1.125rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.5rem;
      }
      .error-page__hint {
        font-size: 0.875rem;
        color: #64748b;
        margin: 0.5rem 0 0;
      }
      .error-page__note {
        margin: 1.25rem 0;
        padding: 0.875rem 1rem;
        border-radius: 0.75rem;
        background: #eff6ff;
        color: #1e3a8a;
        font-size: 1rem;
        font-weight: 600;
      }
      <%!-- Scoped to the text links only (all error templates put theirs in
      __hint / __note). A blanket `.error-page a` would out-specify `.button`
      and paint the primary button's white label blue-on-blue. --%>
      .error-page__hint a, .error-page__note a { color: #1d4ed8; }
      .error-page__hint a { font-weight: 600; }
      .error-page__actions { margin-top: 1.5rem; }
      .error-page code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.875em;
        background: #f1f5f9;
        padding: 0.125rem 0.375rem;
        border-radius: 0.375rem;
      }
      .button {
        display: inline-block;
        background: #1d4ed8;
        color: #ffffff;
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
      }
      .button:hover { background: #1e40af; }

      @media (prefers-color-scheme: dark) {
        body { background: #020617; color: #cbd5e1; }
        .error-shell__brand { color: #ffffff; }
        .error-page { background: #0f172a; outline-color: #1e293b; }
        .error-page__code { color: #334155; }
        .error-page__title { color: #f1f5f9; }
        .error-page__hint { color: #94a3b8; }
        .error-page__note { background: rgb(30 58 138 / 0.35); color: #dbeafe; }
        .error-page__hint a, .error-page__note a { color: #93c5fd; }
        .error-page code { background: #1e293b; }
      }
    </style>
  </head>
  <body>
    <main class="error-shell">
      <a href="/" class="error-shell__brand">vutuv</a>
      {@inner_content}
    </main>
  </body>
</html>
