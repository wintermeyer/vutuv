<.email_layout preheader="Sie wurden auf vutuv empfohlen" locale={@locale}>
  <.email_p>{email_greeting(@user)},</.email_p>
  <.email_p>@{@actor_username} hat Sie für {@tag_name} auf vutuv empfohlen.</.email_p>
  <.email_button href={"#{@url}#{@actor_username}"}>Profil ansehen</.email_button>
  <.email_signature locale={@locale} />
  <.email_unsubscribe_note locale={@locale} unsubscribe_url={@unsubscribe_url} />
</.email_layout>
