<.email_layout preheader="The content you reported was revised" locale={@locale}>
  <.email_p>{email_greeting(@user)},</.email_p>
  <.email_p>
    thank you for your report. The owner has revised the content you reported, and it is visible
    again. If you still believe it breaks our community guidelines, you can report it once more; it
    will then go straight to our admins.
  </.email_p>
  <.email_signature locale={@locale} />
</.email_layout>
