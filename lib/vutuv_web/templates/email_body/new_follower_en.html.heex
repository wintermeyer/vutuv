<.email_layout preheader="You have a new follower on vutuv" locale={@locale}>
  <.email_p>{email_greeting(@user)},</.email_p>
  <.email_p>@{@actor_username} started following you on vutuv.</.email_p>
  <.email_button href={"#{@url}#{@actor_username}"}>See their profile</.email_button>
  <.email_signature locale={@locale} />
  <.email_unsubscribe_note locale={@locale} unsubscribe_url={@unsubscribe_url} />
</.email_layout>
