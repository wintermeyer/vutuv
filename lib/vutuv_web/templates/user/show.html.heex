<%!-- Profile page (Direction A, green-field). Controller + view, no LiveView.
Built from the VutuvWeb.UI kit (<.card>, <.button>, <.avatar>, <.chip>,
<.section_title>). Follow / unfollow / endorse hit the existing POST/DELETE
routes; CSRF + method are handled by the rendered links.

AGENT FORMATS: this page also exists as /:slug.md, .txt, .json, .xml and .vcf,
all rendered from VutuvWeb.AgentDocs.ProfileDoc. When you add or remove
public data here, update ProfileDoc too — agent_docs_drift_test.exs fails
on drift. --%>
<%!-- md, not lg: portrait iPads (768-834px CSS width) get the desktop
content+rail columns too; user_row and the rail cards truncate cleanly at
the resulting ~200px rail width. --%>
<div class="grid gap-6 py-6 md:grid-cols-3">
  <div class="space-y-6 md:col-span-2">
    <%!-- Owner-only "view as" switcher: see your own profile the way others do.
    The bare URL is your own view; ?view_as=follower / connection / public reload server-side
    (the controller filters private data out before render, so it never reaches
    a preview's HTML). A stranger's ?view_as= is ignored, so this is owner-only.
    The bar doubles as the persistent entry point and the active-mode banner. --%>
    <div
      :if={@can_preview?}
      id="view-as-switcher"
      class={[
        "rounded-2xl px-4 py-3 ring-1",
        if(@preview?,
          do: "bg-brand-50 ring-brand-200 dark:bg-brand-900/30 dark:ring-brand-900/50",
          else: "bg-white ring-slate-200 dark:bg-slate-900 dark:ring-slate-800"
        )
      ]}
    >
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
        <span class="inline-flex items-center gap-1.5 font-semibold text-slate-700 dark:text-slate-200">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
          {gettext("View as")}
        </span>
<% view_as_modes = [
          {gettext("You"), nil, ~p"/#{@user}"},
          {gettext("Follower"), :follower, ~p"/#{@user}?#{[view_as: "follower"]}"},
          {gettext("Connected"), :connection, ~p"/#{@user}?#{[view_as: "connection"]}"},
          {gettext("Public"), :public, ~p"/#{@user}?#{[view_as: "public"]}"}
        ] %>
        <%!-- Segmented control: grows to fill the bar (flex-1) with even-width
        segments, so it spans the empty space to the right of the "View as" label
        instead of sitting in a narrow cluster. Hairline dividers keep the segments
        distinct; the active segment is solid brand. --%>
        <div class="flex flex-1 divide-x divide-slate-200 overflow-hidden rounded-lg ring-1 ring-slate-200 dark:divide-slate-700 dark:ring-slate-700">
          <.link
            :for={{label, mode, href} <- view_as_modes}
            href={href}
            aria-current={@preview_as == mode && "true"}
            class={[
              "flex-1 px-3 py-1.5 text-center font-semibold transition-colors",
              if(@preview_as == mode,
                do: "bg-brand-600 text-white",
                else:
                  "bg-white text-slate-600 hover:bg-slate-50 dark:bg-slate-900 dark:text-slate-300 dark:hover:bg-slate-800"
              )
            ]}
          >
            {label}
          </.link>
        </div>
      </div>
      <p :if={@preview?} id="view-as-banner" class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        <%= case @preview_as do %>
          <% :follower -> %>
            {gettext("Preview: how a member who follows you sees your profile. The controls here are inactive.")}
          <% :connection -> %>
            {gettext("Preview: how a member you are connected with sees your profile. The controls here are inactive.")}
          <% :public -> %>
            {gettext("Preview: how logged-out visitors and search engines see your profile.")}
          <% _ -> %>
        <% end %>
      </p>
    </div>

    <%!-- The owner's moderation notice: a frozen / suspended profile is
    invisible to everyone else, so tell the owner what is going on and where
    to act. Visitors never reach this page (EnsureActivated 404s first). --%>
    <.frozen_banner
      :if={@as_owner? and Vutuv.Moderation.account_hidden?(@user)}
      class="rounded-2xl px-4 py-3 text-sm"
    >
      {gettext("Only you can see your profile right now - it is hidden while a report is handled.")}
    </.frozen_banner>

    <%!-- Header card (custom: gradient cover + overlapping avatar) --%>
    <section class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 dark:bg-slate-900 dark:ring-slate-800">
      <%!-- Cover banner: the uploaded cover photo (object-cover crop) when set,
      otherwise the brand gradient. The owner gets a discoverable upload
      affordance overlaid on the banner; it leads to the edit form where the
      cover photo file input lives (alongside the avatar). --%>
      <% cover_url = Vutuv.Cover.display_url(@user, :wide) %>
      <div class="relative h-28">
        <%= if cover_url do %>
          <img src={cover_url} alt={gettext("Cover photo of %{name}", name: full_name(@user))} class="h-full w-full object-cover" />
        <% else %>
          <div class="h-full w-full bg-gradient-to-r from-brand-700 to-brand-500"></div>
        <% end %>
        <.link
          :if={@as_owner?}
          href={~p"/#{@user}/edit"}
          title={if cover_url, do: gettext("Change cover photo"), else: gettext("Add a cover photo")}
          class="absolute right-3 top-3 inline-flex items-center gap-1.5 rounded-lg bg-black/30 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur transition hover:bg-black/50"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z" />
          </svg>
          {if cover_url, do: gettext("Change cover"), else: gettext("Add cover photo")}
        </.link>
      </div>
      <div class="px-6 pb-6">
        <div class="-mt-12 flex items-end gap-4">
          <%!-- relative z-10: the cover banner above is `relative` (for its
          upload overlay), which puts it in the positioned paint layer; without
          this the static avatar would render behind the banner instead of
          overlapping on top of it. --%>
          <.avatar user={@user} size="lg" shape="square" loading="eager" alt={"Avatar of #{full_name(@user)}"} class="relative z-10 ring-4 ring-white dark:ring-slate-900" presence />
          <%!-- flex-wrap: on narrow phones the visitor's three controls
          (Connect/Follow/Message) don't fit beside the avatar in one row;
          without it the last button is clipped off-screen. --%>
          <%!-- pointer-events-none in preview: the visitor controls render so
          the owner sees exactly what a member gets, but they are inert (you
          cannot connect to / message yourself). --%>
          <div
            id="profile-actions"
            class={["ml-auto flex flex-wrap justify-end gap-2 pb-1", @preview? && "pointer-events-none"]}
          >
            <%= cond do %>
              <% @as_owner? -> %>
                <.button href={~p"/#{@user}/edit"}>{gettext("Edit profile")}</.button>
              <% assigns[:viewer_block] -> %>
                <%!-- I blocked this member: no Connect/Follow/Message (they
                would all refuse anyway) - the footer offers Unblock. --%>
              <% @preview_as in [:follower, :connection] or visitor?(@conn, @current_user) -> %>
                <.connect_control
                  :if={@connection_state}
                  state={@connection_state.status}
                  target_id={@user.id}
                  connection_id={@connection_state.connection && @connection_state.connection.id}
                />
                <.follow_button
                  variant="button"
                  follower_id={@current_user_id}
                  followee_id={@user.id}
                  follow_id={@header_follow_id}
                />
                <.button variant="secondary" href={~p"/messages/with/#{@user}"}>{gettext("Message")}</.button>
                <%!-- Private, silent saves (no follow/connection, no notification):
                bookmark or like this member. Shown to any logged-in non-owner; the
                block branch above renders no controls at all. --%>
                <.user_bookmark_button :if={@user_saved} saved?={@user_saved.bookmarked?} target_id={@user.id} />
                <.user_like_button :if={@user_saved} saved?={@user_saved.liked?} target_id={@user.id} />
              <% true -> %>
            <% end %>
          </div>
        </div>

        <h1 class="mt-4 flex items-center gap-2 text-2xl font-bold text-slate-900 dark:text-white">
          {full_name(@user)}
          <span :if={@user.identity_verified?} title={gettext("Verified profile")} class="text-brand-600 dark:text-brand-400">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 5v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V5l-8-3Zm-1.2 13.4-3.5-3.5 1.4-1.4 2.1 2.1 4.6-4.6 1.4 1.4-6 6Z"/></svg>
          </span>
        </h1>
        <%!-- Headline is user-written Markdown, rendered through the same safe
        VutuvWeb.Markdown pipeline as chat messages. Earmark wraps the output in
        a <p>, so the host is a <div>; the arbitrary-variant classes flatten that
        paragraph and style inline links/code to match the muted sub-line. --%>
        <div
          :if={@user.headline}
          class="text-slate-500 dark:text-slate-400 [&_p]:m-0 [&_p+p]:mt-1 [&_a]:text-brand-600 dark:[&_a]:text-brand-400 [&_a]:hover:text-brand-700 [&_code]:rounded [&_code]:bg-black/10 [&_code]:px-1 [&_code]:font-mono [&_code]:text-[0.9em] dark:[&_code]:bg-white/10"
        >
          {VutuvWeb.Markdown.render(@user.headline)}
        </div>
        <p :if={@work_info not in [nil, ""]} class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">
          {@work_info}
        </p>

        <% member_since = member_since(@user) %>
        <% has_counts = @follower_count > 0 or @followee_count > 0 or @connection_count > 0 %>

        <%!-- Counts row: each counter is hidden when its total is 0 (a bare "0"
        with no label says nothing). Left-aligned. "Member since" used to ride
        the right end of this line via ml-auto, but on a narrow phone it wrapped
        to a lone right-aligned line that read as orphaned and left the card
        lopsided; it now anchors the left of the footer row below, opposite the
        actions. --%>
        <div :if={has_counts} class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-1 text-sm">
          <.link :if={@follower_count > 0} href={~p"/#{@user}/followers"} class="hover:underline">
            <span class="font-bold text-slate-900 dark:text-white">{compact_count(@follower_count)}</span>
            <span class="text-slate-500">{ngettext("follower", "followers", @follower_count)}</span>
          </.link>
          <.link :if={@followee_count > 0} href={~p"/#{@user}/following"} class="hover:underline">
            <span class="font-bold text-slate-900 dark:text-white">{compact_count(@followee_count)}</span>
            <span class="text-slate-500">{gettext("following")}</span>
          </.link>
          <.link
            :if={@connection_count > 0}
            id="profile-connections"
            href={~p"/#{@user}/connections"}
            class="hover:underline"
          >
            <span class="font-bold text-slate-900 dark:text-white">{compact_count(@connection_count)}</span>
            <span class="text-slate-500">{ngettext("connection", "connections", @connection_count)}</span>
          </.link>
        </div>

        <%!-- Footer row: "Member since" anchors the left and the actions
        (report / block / vCard) cluster on the right, so the hairline-divided
        row carries weight on both ends instead of stacking everything against
        the right edge (which left all the empty space on the left). vCard is
        the download of this profile as a .vcf, shown to everyone including the
        owner; it replaces the old standalone "Exports" rail card. --%>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-slate-100 pt-3 dark:border-slate-800">
          <%!-- my-0 neutralises the default <p> margin from components.css, which
          would otherwise inflate the margin-box and lift the text above the
          vCard baseline under the row's items-center. --%>
          <.member_since_line :if={member_since} value={member_since} class="my-0" />
          <div class="ml-auto flex items-center gap-4">
            <%!-- The quiet escape hatch: report this profile. Deliberately muted
            (footer, slate, no fill) so it is findable when needed but never in
            the way. Logged-in non-owners only. --%>
            <.link
              :if={@current_user && not same_user?(@user, @current_user)}
              id="report-profile"
              href={~p"/reports/new?#{[type: "user", id: @user.id, return_to: "/#{@user.active_slug}"]}"}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400"
            >
            <span aria-hidden="true">⚑</span>
            {gettext("Report")}
          </.link>
          <%!-- Block / Unblock: as quiet as Report. Blocking severs follows +
          connection, freezes the conversation and stops all interaction both
          ways (Vutuv.Social.block_user/2); unblocking restores nothing. --%>
          <.link
            :if={@current_user && not same_user?(@user, @current_user) && is_nil(@viewer_block)}
            id="block-user"
            href={~p"/blocks?#{[block: [user_id: @user.id]]}"}
            method="post"
            data-confirm={
              gettext(
                "Block @%{slug}? This removes any follows and connection between you, closes your conversation, and prevents all interaction in both directions. Unblocking will not restore what was removed.",
                slug: @user.active_slug
              )
            }
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400"
          >
            {gettext("Block")}
          </.link>
          <.link
            :if={@viewer_block}
            id="unblock-user"
            href={~p"/blocks/#{@viewer_block.id}"}
            method="delete"
            data-confirm={gettext("Unblock @%{slug}?", slug: @user.active_slug)}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-700 dark:hover:text-brand-300"
          >
            {gettext("Unblock")}
          </.link>
          <%!-- A permitted viewer (the owner, or a member they follow back)
          gets the session-aware export with all their email addresses; an
          anonymous visitor gets the public .vcf. --%>
          <.link
            id="download-vcard"
            href={
              if @vcard_full?,
                do: ~p"/#{@user}/vcard",
                else: "/#{@user.active_slug}.vcf"
            }
            title={gettext("Download")}
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            {gettext("vCard")}
          </.link>
          </div>
        </div>
      </div>
    </section>

    <%!-- New-member onboarding checklist: the few highest-impact steps so a fresh
    profile becomes findable and recognizable fast. Owner-only, shown while
    anything is still undone and gone once every step is done; each todo links
    straight to where it is done. Replaces the old 10-minute welcome note. --%>
    <section
      :if={@as_owner? and Enum.any?(@completion_steps, &(not &1.done))}
      class="rounded-2xl bg-brand-50 p-6 ring-1 ring-brand-100 dark:bg-brand-900/30 dark:ring-brand-900/50"
    >
      <% done_count = Enum.count(@completion_steps, & &1.done) %>
      <% total = Enum.count(@completion_steps) %>
      <div class="flex items-baseline justify-between gap-3">
        <h2 class="font-semibold text-brand-800 dark:text-brand-100">{gettext("Complete your profile")}</h2>
        <span class="text-sm font-semibold tabular-nums text-brand-700 dark:text-brand-200">
          {done_count}/{total}
        </span>
      </div>
      <p class="mt-1 text-sm text-brand-700/80 dark:text-brand-200/80">
        {gettext("A few quick steps so people can find and recognize you.")}
      </p>
      <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-brand-100 dark:bg-brand-900/50">
        <div class="h-full rounded-full bg-brand-600 transition-all" style={"width: #{round(done_count / total * 100)}%"}></div>
      </div>
      <ul class="mt-4 space-y-2">
        <li :for={step <- @completion_steps} class="flex items-center gap-3">
          <%= if step.done do %>
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-600 text-white" aria-hidden="true">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            </span>
            <span class="text-sm text-brand-700/50 line-through dark:text-brand-200/40">{step.label}</span>
          <% else %>
            <span class="h-5 w-5 shrink-0 rounded-full border-2 border-brand-300 dark:border-brand-700" aria-hidden="true"></span>
            <.link href={step.href} class="text-sm font-medium text-brand-800 hover:underline dark:text-brand-100">
              {step.label}
            </.link>
          <% end %>
        </li>
      </ul>
    </section>

    <%!-- Posts (latest visible to this viewer; writing happens in the /feed
    composer, which the owner's "Add" link points to) --%>
    <.card :if={@posts != [] or @as_owner?} id="profile-posts">
      <.section_header title={gettext("Posts")} />

      <%!-- Compose affordance on top, the convention everywhere (the feed opens
      in the /feed composer). --%>
      <.empty_add :if={@as_owner?} href={~p"/feed"} class={@posts != [] && "mb-4"}>
        {if @posts == [], do: gettext("Write your first post"), else: gettext("Write a post")}
      </.empty_add>

      <div :if={@posts != []} class="divide-y divide-slate-100 dark:divide-slate-800">
        <.post_card
          :for={entry <- @posts}
          post={entry.post}
          reposted_by={entry.reposted_by}
          entry_id={entry.id}
          conn_or_socket={@conn}
          viewer={@view_viewer}
          mode={:preview}
          surface={:flat}
          class="py-4 first:pt-0 last:pb-0"
        />
      </div>

      <%!-- Content navigation: only when there is more than the profile shows. --%>
      <.card_footer_link :if={@posts_total > length(@posts)} href={~p"/#{@user}/posts"}>
        {gettext("View all %{count} posts", count: compact_count(@posts_total))}
      </.card_footer_link>
    </.card>

    <%!-- Tags --%>
    <.card :if={Enum.count(@user_tags) > 0 or @as_owner?}>
      <%!-- The dashed add tile is onboarding scaffolding: it shows only while the
      card is empty. Once there are entries the card is a clean showcase and
      "Verwalten" (manage_footer) leads to the page where tags are added/removed
      (tags have no edit form). --%>
      <.section_header title={gettext("Tags")} />

      <.empty_add :if={@as_owner? and Enum.count(@user_tags) == 0} href={~p"/#{@user}/tags/new"}>
        {gettext("Add a tag")}
      </.empty_add>

      <div :if={Enum.count(@user_tags) > 0} class="flex flex-wrap gap-2">
        <div :for={user_tag <- @user_tags} class="inline-flex items-center">
          <.chip href={~p"/#{@user}/tags/#{user_tag}"}>
            {Vutuv.Tags.UserTag.truncated_name(user_tag)}
            <span class="rounded bg-brand-600 px-1.5 text-xs font-semibold text-white">{compact_count(Enum.count(user_tag.endorsements))}</span>
          </.chip>
          <%!-- Endorsements are preloaded, so check in memory (no per-tag query). --%>
          <%= if @current_user && not same_user?(@user, @current_user) && not Enum.any?(user_tag.endorsements, &(&1.user_id == @current_user_id)) do %>
            <%= button to: ~p"/#{@user}/user_tag_endorsements?#{[id: user_tag]}",
                  method: :post,
                  title: gettext("Endorse"),
                  class: "ml-1 flex h-7 w-7 items-center justify-center rounded-full text-slate-600 dark:text-slate-400 hover:bg-brand-50 hover:text-brand-600 dark:hover:bg-slate-800" do %>
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5h1.5v9h-3v-7.5a1.5 1.5 0 0 1 1.5-1.5Zm0 0V9a3 3 0 0 1 3-3l.4.04a2 2 0 0 1 1.6 2.6l-.9 2.86h4.27a2 2 0 0 1 1.98 2.3l-.86 5.5a2 2 0 0 1-1.98 1.7H8.133"/></svg>
            <% end %>
          <% end %>
        </div>
      </div>

      <.manage_footer
        href={~p"/#{@user}/tags"}
        total={@totals.user_tags}
        preview={10}
        owner={@as_owner?}
      />
    </.card>

    <%!-- Experience --%>
    <.card :if={@work_experience != [] or @as_owner?} id="profile-experience">
      <.section_header title={gettext("Experience")} />

      <.empty_add :if={@as_owner? and @work_experience == []} href={~p"/#{@user}/work_experiences/new"}>
        {gettext("Add work experience")}
      </.empty_add>

      <%!-- The single-letter "organization initial" boxes were dropped: one
      letter says nothing about a job. Each role shows a year-led date range (the
      full month/year rides along as a hover tooltip when the role spans several
      years), the title and organization on a rail, and a duration circle on the
      right whose size (sqrt of its length, so the gaps stay legible) ranks the
      roles by how long they ran. The circle column is a fixed width and the
      circle is centred in it, so every circle shares one horizontal centre.
      Work experiences arrive newest-first (WorkExperience.order_by_date). --%>
      <div :if={@work_experience != []}>
        <div
          :for={circle <- VutuvWeb.WorkExperienceHTML.circle_durations(@work_experience, :compact)}
          class="grid grid-cols-[6.5rem_1fr_4rem] items-start gap-3"
        >
          <% dates =
            VutuvWeb.WorkExperienceHTML.duration_with_detail(
              circle.job.start_month,
              circle.job.start_year,
              circle.job.end_month,
              circle.job.end_year
            ) %>
          <div
            class="pt-0.5 text-right text-xs font-semibold leading-tight text-slate-500 dark:text-slate-400 tabular-nums"
            title={dates.detail}
          >
            {dates.label}
          </div>
          <div class="relative border-l border-slate-200 pb-6 pl-5 dark:border-slate-700">
            <span class="absolute -left-[0.3125rem] top-1.5 h-2.5 w-2.5 rounded-full bg-brand-600 ring-4 ring-white dark:ring-slate-900"></span>
            <.link href={~p"/#{@user}/work_experiences/#{circle.job}"} class="font-semibold text-slate-900 hover:text-brand-700 dark:text-white">
              {circle.job.title}
            </.link>
            <p class="text-sm text-slate-500">
              {circle.job.organization}<%= if circle.length do %> · {circle.length}<% end %>
            </p>
          </div>
          <div
            class="flex shrink-0 items-center justify-center justify-self-center rounded-full bg-brand-600 font-semibold tabular-nums leading-none text-white"
            style={"width: #{circle.size}rem; height: #{circle.size}rem"}
            title={gettext("Time in this role")}
          >
            <span class="text-[11px]">{circle.label}</span>
          </div>
        </div>
      </div>

      <.manage_footer
        href={~p"/#{@user}/work_experiences"}
        total={@totals.jobs}
        preview={3}
        owner={@as_owner?}
      />
    </.card>

    <%!-- Links: preview cards built from the page screenshots that
    Vutuv.PageScreenshot captures on link create/update. Lives in the wide
    main column so the thumbnails get room; Vutuv.Screenshot.url/2 falls back
    to the bundled placeholder while a screenshot is still missing. --%>
    <.card :if={@totals.links > 0 or @as_owner?} id="profile-links">
      <.section_header title={gettext("Links")} />
      <.empty_add :if={@as_owner? and @totals.links == 0} href={~p"/#{@user}/links/new"}>
        {gettext("Add a link")}
      </.empty_add>
      <%!-- sm:gap-x-18 widens only the desktop column gutter to 72px so both
      thumbnail columns line up edge-for-edge with the Followers/Following
      cards below. That row is two p-6 cards in a gap-6 grid, so its content
      channel is 24 + 24 + 24 = 72px. Row + mobile gap stay gap-4 (these are
      one card's thumbnails, not two cards stacking). --%>
      <div :if={@user.urls != []} class="grid gap-4 sm:grid-cols-2 sm:gap-x-18">
        <div :for={url <- @user.urls}>
          <a
            href={VutuvWeb.UrlHTML.linkable_url(url.value)}
            class="block overflow-hidden rounded-lg ring-1 ring-slate-200 dark:ring-slate-800"
          >
            <img
              src={Vutuv.Screenshot.url({url.screenshot, url}, :thumb)}
              alt={url.description || url.value}
              width="400"
              height="264"
              loading="lazy"
              class="aspect-[400/264] w-full object-cover"
            />
          </a>
          <div class="mt-2 min-w-0 text-sm">
            <p :if={url.description} class="mb-0.5 truncate font-medium text-slate-800 dark:text-slate-100">{url.description}</p>
            <a
              href={VutuvWeb.UrlHTML.linkable_url(url.value)}
              title={url.value}
              class="block truncate font-medium text-brand-600 hover:text-brand-700"
            >
              {VutuvWeb.UrlHTML.display_url(url.value)}
            </a>
          </div>
        </div>
      </div>
      <.manage_footer
        href={~p"/#{@user}/links"}
        total={@totals.links}
        preview={3}
        owner={@as_owner?}
      />
    </.card>

    <%!-- Follower / following previews (latest 3 each, full lists behind "View All").
    Side by side in two columns on sm+, stacked on mobile. --%>
    <div class="grid gap-6 sm:grid-cols-2">
      <.card :if={@follower_count > 0} id="profile-followers">
        <.section_title class="mb-4">{gettext("Followers")}</.section_title>
        <ul class="space-y-4">
          <.user_row
            :for={user <- @followers}
            user={user}
            current_user={@view_viewer}
            current_user_id={@view_viewer_id}
            work_info_by_id={@work_info_by_id}
            following_by_id={@following_by_id}
          />
        </ul>
        <.card_footer_link :if={@follower_count > 3} href={~p"/#{@user}/followers"}>
          {gettext("View All")} ({compact_count(@follower_count)})
        </.card_footer_link>
      </.card>

      <.card :if={@followee_count > 0} id="profile-following">
        <.section_title class="mb-4">
          {if @as_owner?, do: gettext("Following"), else: gettext("Follows")}
        </.section_title>
        <ul class="space-y-4">
          <.user_row
            :for={user <- @followees}
            user={user}
            current_user={@view_viewer}
            current_user_id={@view_viewer_id}
            work_info_by_id={@work_info_by_id}
            following_by_id={@following_by_id}
          />
        </ul>
        <.card_footer_link :if={@followee_count > 3} href={~p"/#{@user}/following"}>
          {gettext("View All")} ({compact_count(@followee_count)})
        </.card_footer_link>
      </.card>
    </div>
  </div>

  <%!-- Right rail --%>
  <aside class="space-y-6">
    <.card :if={Enum.count(@emails) > 0 or @as_owner?} id="profile-contact">
      <.section_header title={gettext("Contact")} />
      <.empty_add :if={@as_owner? and Enum.count(@emails) == 0} href={~p"/#{@user}/emails/new"}>
        {gettext("Add an email address")}
      </.empty_add>
      <%!-- Icon line: envelope + address on one line; the type (Work/Personal) is
      a small muted suffix shown only when meaningful ("Other" is the unspecified
      default). No separate label line. --%>
      <ul class="-my-1 text-sm">
        <li :for={email <- @emails}>
          <a
            href={"mailto:#{email.value}"}
            class="group flex items-center gap-2.5 py-1.5 text-brand-600 hover:text-brand-700"
          >
            <.detail_icon name="envelope" class="h-4 w-4 shrink-0 text-slate-400 transition group-hover:text-brand-600 dark:text-slate-500" />
            <span class="min-w-0 break-all font-medium">{email.value}</span>
            <span
              :if={email.email_type && email.email_type != "Other"}
              class="ml-auto shrink-0 text-xs font-normal text-slate-500 dark:text-slate-400"
            >
              {email.email_type}
            </span>
          </a>
        </li>
      </ul>
      <.manage_footer
        href={~p"/#{@user}/emails"}
        total={Enum.count(@emails)}
        preview={Enum.count(@emails)}
        owner={@as_owner?}
      />
    </.card>

    <%!-- General info: gender + birthday; the headline already lives in the header --%>
    <.card
      :if={@user.birthdate || (@user.gender && @user.gender != "other") || @as_owner?}
      id="profile-about"
    >
      <%!-- General Info edits the profile form (no list). While empty it shows
      the dashed "add personal details" onboarding tile; once gender/birthday are
      set it is a clean showcase with a quiet "Ändern" footer to /edit. --%>
      <% has_general_info = @user.birthdate || (@user.gender && @user.gender != "other") %>
      <.section_header title={gettext("General Info")} />
      <.empty_add :if={@as_owner? && !has_general_info} href={~p"/#{@user}/edit"}>
        {gettext("Add personal details")}
      </.empty_add>
      <%!-- Icon rows: one line per datum (person = gender, cake = birthday); the
      label is screen-reader-only since the icon carries it. The dd needs `my-0`
      to cancel the legacy global `dl dd { margin: 10px 0 }` in components.css,
      which otherwise pads each row; a tight `gap-1.5` then sets the row rhythm. --%>
      <dl :if={has_general_info} class="flex flex-col gap-1.5 text-sm">
        <div :if={@user.gender && @user.gender != "other"} class="flex items-center gap-2.5">
          <.detail_icon name="user" class="h-4 w-4 shrink-0 text-slate-400 dark:text-slate-500" />
          <dt class="sr-only">{gettext("Gender")}</dt>
          <dd class="my-0 font-medium text-slate-800 dark:text-slate-100">{Vutuv.Accounts.User.gender_gettext(@user.gender)}</dd>
        </div>
        <div :if={@user.birthdate} class="flex items-center gap-2.5">
          <.detail_icon name="cake" class="h-4 w-4 shrink-0 text-slate-400 dark:text-slate-500" />
          <dt class="sr-only">{gettext("Birthday")}</dt>
          <dd class="my-0 font-medium text-slate-800 dark:text-slate-100">{format_birthdate(@user)}</dd>
        </div>
      </dl>
      <.card_footer_link :if={@as_owner? && has_general_info} href={~p"/#{@user}/edit"}>
        {gettext("Edit")}
      </.card_footer_link>
    </.card>

    <.card
      :if={Enum.count(@user.social_media_accounts) > 0 or @as_owner?}
      id="profile-social-media"
    >
      <.section_header title={gettext("Social Media")} />
      <.empty_add :if={@as_owner? and Enum.count(@user.social_media_accounts) == 0} href={~p"/#{@user}/social_media_accounts/new"}>
        {gettext("Add a social media account")}
      </.empty_add>

      <%!-- One line per account: brand glyph + handle. The provider name is
      dropped (the icon carries it), so this is half the height of the old
      two-line-per-account stack. --%>
      <ul class="-my-1.5 text-sm">
        <li :for={account <- @user.social_media_accounts}>
          <.social_link
            account={account}
            class="group flex items-center gap-2.5 py-1.5 text-slate-700 transition hover:text-brand-700 dark:text-slate-200"
          >
            <.social_icon
              provider={account.provider}
              class="h-4 w-4 shrink-0 text-slate-400 transition group-hover:text-brand-600 dark:text-slate-500 dark:group-hover:text-brand-300"
            />
            <span class="truncate font-medium">{social_handle(account)}</span>
          </.social_link>
        </li>
      </ul>

      <.manage_footer
        href={~p"/#{@user}/social_media_accounts"}
        total={Enum.count(@user.social_media_accounts)}
        preview={Enum.count(@user.social_media_accounts)}
        owner={@as_owner?}
      />
    </.card>

    <.card :if={@totals.numbers > 0 or @as_owner?} id="profile-phone-numbers">
      <.section_header title={gettext("Phone Numbers")} />
      <.empty_add :if={@as_owner? and @totals.numbers == 0} href={~p"/#{@user}/phone_numbers/new"}>
        {gettext("Add a phone number")}
      </.empty_add>
      <%!-- Icon line: phone glyph + number, the type a small muted suffix. --%>
      <ul class="-my-1 text-sm">
        <li :for={number <- @user.phone_numbers}>
          <a
            href={"tel:" <> Vutuv.Phone.tel(number.value)}
            class="group flex items-center gap-2.5 py-1.5 text-brand-600 hover:text-brand-700"
          >
            <.detail_icon name="phone" class="h-4 w-4 shrink-0 text-slate-400 transition group-hover:text-brand-600 dark:text-slate-500" />
            <span class="font-medium">{Vutuv.Phone.national(number.value, @conn.assigns[:locale])}</span>
            <span
              :if={number.number_type}
              class="ml-auto shrink-0 text-xs font-normal text-slate-500 dark:text-slate-400"
            >
              {number.number_type}
            </span>
          </a>
        </li>
      </ul>
      <.manage_footer
        href={~p"/#{@user}/phone_numbers"}
        total={@totals.numbers}
        preview={3}
        owner={@as_owner?}
      />
    </.card>

    <.card :if={@totals.addresses > 0 or @as_owner?} id="profile-addresses">
      <.section_header title={gettext("Addresses")} />
      <.empty_add :if={@as_owner? and @totals.addresses == 0} href={~p"/#{@user}/addresses/new"}>
        {gettext("Add an address")}
      </.empty_add>
      <%!-- Icon block: a map-pin leads the entry; the description is the bold
      title and the full address sits muted below it, tightened with
      leading-snug. --%>
      <ul class="-my-1.5 text-sm">
        <li :for={address <- @user.addresses} class="flex items-start gap-2.5 py-1.5">
          <.detail_icon name="map-pin" class="mt-0.5 h-4 w-4 shrink-0 text-slate-400 dark:text-slate-500" />
          <div class="min-w-0 leading-snug">
            <p class="mb-0 font-medium text-slate-800 dark:text-slate-100">{address.description}</p>
            <div class="text-slate-600 dark:text-slate-400">{format_address(address)}</div>
          </div>
        </li>
      </ul>
      <.manage_footer
        href={~p"/#{@user}/addresses"}
        total={@totals.addresses}
        preview={3}
        owner={@as_owner?}
      />
    </.card>

    <%!-- This profile in agent-/machine-readable formats (VutuvWeb.AgentDocs):
    the same page as Markdown, plain text, JSON, XML and vCard. A human visitor
    browsing in German gets the German rendering via ?lang=; the canonical
    extension URLs (head alternates, llms.txt) stay English. --%>
    <% format_lang =
      if @conn.assigns[:locale] in [nil, "en"], do: "", else: "?lang=#{@conn.assigns[:locale]}" %>
    <.card id="profile-other-formats">
      <.section_title class="mb-4">{gettext("Other formats")}</.section_title>
      <%!-- The vCard carries no translatable labels, so it skips ?lang=. --%>
      <% formats = [
        {gettext("Markdown"), "/#{@user.active_slug}.md#{format_lang}"},
        {gettext("Text only"), "/#{@user.active_slug}.txt#{format_lang}"},
        {"JSON", "/#{@user.active_slug}.json#{format_lang}"},
        {"XML", "/#{@user.active_slug}.xml#{format_lang}"},
        {gettext("vCard"), "/#{@user.active_slug}.vcf"}
      ] %>
      <%!-- Chips: a wrapping row of small tags instead of a five-row list. --%>
      <div class="flex flex-wrap gap-1.5">
        <.link
          :for={{label, href} <- formats}
          href={href}
          class="inline-flex items-center rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 transition hover:bg-brand-50 hover:text-brand-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-brand-900/30 dark:hover:text-brand-200"
        >
          {label}
        </.link>
      </div>
    </.card>

    <%!-- "Who to follow" sits at the foot of the rail on purpose: the profile's
    own details (contact, info, links) lead, and discovery of other people
    follows after them rather than above them. --%>
    <.card :if={Enum.count(@recommended_users) > 0}>
      <.section_title class="mb-4">{gettext("Who to follow")}</.section_title>
      <ul class="space-y-4">
        <.user_row
          :for={user <- @recommended_users}
          user={user}
          current_user={@view_viewer}
          current_user_id={@view_viewer_id}
          work_info_by_id={@work_info_by_id}
          following_by_id={@following_by_id}
        />
      </ul>
    </.card>
  </aside>
</div>

<JsonLd.script data={JsonLd.breadcrumbs(@user)} />
<%!-- Markup mirrors the page (schema.org accuracy rule): a noindexed
member's profile carries no Person entity. --%>
<JsonLd.script
  :if={not @user.noindex?}
  data={JsonLd.person(@user, @header_job, @user_tags, @user.social_media_accounts)}
/>
