
<div class="breadcrumbs">
  <%= gen_breadcrumbs([
    gettext("Users"),
    {full_name(@user), ~p"/users/#{@user}"},
    {gettext("Addresses"), ~p"/users/#{@user}/addresses"},
    gettext("New")]) %>
</div>


<div class="card-list">

  <section class="card">

  <%= render "form_"<>@country<>".html", backlink: ~p"/users/#{@user}/addresses", changeset: @changeset, conn: @conn, action: ~p"/users/#{@user}/addresses" %>
  </section>
</div>
