<.page_header
  title={gettext("Addresses of %{name}", name: full_name(@user))}
  crumbs={[
    gettext("Users"),
    {full_name(@user), ~p"/#{@user}"},
    gettext("Addresses")
  ]}
/>

<.card_section
  empty={Enum.empty?(@addresses)}
  add_href={same_user?(@user, @current_user) && ~p"/#{@current_user}/addresses/new"}
>
  <%= render "card_list.html", assigns %>
</.card_section>
