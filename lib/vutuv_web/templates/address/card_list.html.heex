<div class="card__tablewrap">
<table>
  <thead>
    <tr>
      <th><%= gettext "Description" %></th>
      <th><%= gettext "Address" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <%= for address <- @addresses do %>
    <tr>
      <td>
      <%!-- A description is optional (the welcome page may store a location
            without one), so fall back to the generic word like the show page. --%>
      <%= link address.description || gettext("Address"), to: ~p"/#{@user}/addresses/#{address}" %>
      </td>
      <td><%= format_address address, @conn.assigns[:locale] %></td>
      <td class="text-right">
        <.row_actions
          :if={@as_owner?}
          edit_to={~p"/settings/addresses/#{address}/edit"}
          delete_to={~p"/settings/addresses/#{address}"}
        />
      </td>
    </tr>
<% end %>
  </tbody>
</table>
</div>
