<.editform_field form={@form} field={:country}>
  <%= label @form, gettext("Country") %>
  <%!-- The list is VutuvWeb.AddressHTML.country_names/0, shared with the
        one-time welcome page so the two can never offer different countries. --%>
  <%= select @form, :country, country_names(), prompt: gettext("Select a Country") %>
</.editform_field>
