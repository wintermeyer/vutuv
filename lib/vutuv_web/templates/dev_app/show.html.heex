<.page_header
  title={@app.name}
  crumbs={[
    {gettext("Developers"), ~p"/developers"},
    {gettext("Applications"), ~p"/developers/apps"},
    @app.name
  ]}
/>

<div class="card-list">
  <section class="card" id="dev-app">
    <p :if={@app.suspended_at} class="mb-4 text-sm font-semibold text-red-600">
      {gettext("This application was suspended by the operator. Its tokens are refused.")}
    </p>

    <.secret_once
      flash={@flash}
      key={:new_app_secret}
      label={gettext("Your client secret. Copy it now, it will not be shown again:")}
      class="mb-4"
    />

    <dl class="space-y-3 text-sm">
      <div>
        <dt class="font-semibold text-slate-500 dark:text-slate-400">{gettext("Client ID")}</dt>
        <dd>
          <code class="select-all text-slate-800 dark:text-slate-100">{@app.client_id}</code>
        </dd>
      </div>
      <div>
        <dt class="font-semibold text-slate-500 dark:text-slate-400">
          {gettext("Client secret")}
        </dt>
        <dd class="text-slate-700 dark:text-slate-200">
          {gettext("Stored as a hash; only shown right after generating it.")}
        </dd>
      </div>
      <div>
        <dt class="font-semibold text-slate-500 dark:text-slate-400">
          {gettext("Redirect URLs")}
        </dt>
        <dd>
          <ul>
            <li :for={uri <- @app.redirect_uris}>
              <code class="text-slate-800 dark:text-slate-100">{uri}</code>
            </li>
          </ul>
        </dd>
      </div>
      <div :if={@app.description}>
        <dt class="font-semibold text-slate-500 dark:text-slate-400">{gettext("Description")}</dt>
        <dd class="text-slate-700 dark:text-slate-200">{@app.description}</dd>
      </div>
    </dl>

    <div class="mt-6 flex flex-wrap gap-3 border-t border-slate-100 pt-4 dark:border-slate-800">
      <.button href={~p"/developers/apps/#{@app.id}/edit"} variant="secondary">
        {gettext("Edit")}
      </.button>
      <.button
        href={~p"/developers/apps/#{@app.id}/regenerate_secret"}
        method="post"
        variant="secondary"
        data-confirm={gettext("Generate a new client secret? The current one stops working.")}
      >
        {gettext("New client secret")}
      </.button>
    </div>

    <p class="mt-6 text-sm text-slate-500 dark:text-slate-400">
      {gettext("Authorize URL:")} <code>https://vutuv.de/oauth/authorize</code>
      &middot; {gettext("Token URL:")} <code>https://vutuv.de/oauth/token</code>
      &middot;
      <a
        href={~p"/developers/authentication"}
        class="font-semibold text-brand-600 hover:text-brand-700"
      >
        {gettext("Documentation")}
      </a>
    </p>
  </section>

  <section class="card" id="dev-app-webhooks">
    <.section_header title={gettext("Webhooks")} />

    <.secret_once
      flash={@flash}
      key={:new_webhook_secret}
      label={gettext("Your webhook signing secret. Copy it now, it will not be shown again:")}
      class="mb-4"
    />

    <%= if @webhooks == [] do %>
      <p class="card__empty">
        {gettext("No webhooks. vutuv can notify your server about events as they happen.")}
      </p>
    <% else %>
      <ul class="divide-y divide-slate-100 dark:divide-slate-800">
        <%= for webhook <- @webhooks do %>
          <li class="flex flex-wrap items-start gap-3 py-4 first:pt-0 last:pb-0">
            <div class="min-w-0 flex-1">
              <p class="truncate font-medium text-slate-800 dark:text-slate-100">
                <code>{webhook.url}</code>
              </p>
              <p class="text-sm text-slate-500 dark:text-slate-400">
                {Enum.join(webhook.events, ", ")}
              </p>
              <p :if={not webhook.active} class="text-sm font-semibold text-red-600">
                {gettext("Disabled: %{reason}", reason: webhook.disabled_reason)}
              </p>
            </div>
            <div class="flex gap-2">
              <.button
                :if={webhook.active}
                href={~p"/developers/apps/#{@app.id}/webhooks/#{webhook.id}/ping"}
                method="post"
                variant="secondary"
              >
                {gettext("Send ping")}
              </.button>
              <.button
                :if={not webhook.active}
                href={~p"/developers/apps/#{@app.id}/webhooks/#{webhook.id}/reactivate"}
                method="post"
                variant="secondary"
              >
                {gettext("Re-enable")}
              </.button>
              <.button
                href={~p"/developers/apps/#{@app.id}/webhooks/#{webhook.id}"}
                method="delete"
                variant="danger"
                data-confirm={gettext("Delete this webhook?")}
              >
                {gettext("Delete")}
              </.button>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>

    <div class="mt-4">
      <a
        href={~p"/developers/apps/#{@app.id}/webhooks/new"}
        class="text-sm font-semibold text-brand-600 hover:text-brand-700"
        id="add-webhook-link"
      >
        {gettext("Add a webhook")} ›
      </a>
    </div>
  </section>
</div>
