<.form :let={f} for={@changeset} as={:app} action={@action} class="editform">
  <.form_error changeset={@changeset} />

  <div class={"editform__field#{if error_tag(f, :name), do: " editform__field--error"}"}>
    <%= label(f, :name, gettext("Name")) %>
    <%= text_input(f, :name, autofocus: true) %>
    <p class="editform__hint">
      {gettext("Members see this name on the consent screen.")}
    </p>
    <%= error_tag(f, :name) %>
  </div>

  <div class={"editform__field#{if error_tag(f, :description), do: " editform__field--error"}"}>
    <%= label(f, :description, gettext("Description")) %>
    <%= textarea(f, :description, rows: 3) %>
    <%= error_tag(f, :description) %>
  </div>

  <div class={"editform__field#{if error_tag(f, :homepage_url), do: " editform__field--error"}"}>
    <%= label(f, :homepage_url, gettext("Homepage")) %>
    <%= text_input(f, :homepage_url, placeholder: "https://…") %>
    <%= error_tag(f, :homepage_url) %>
  </div>

  <div class={"editform__field#{if error_tag(f, :redirect_uris), do: " editform__field--error"}"}>
    <%= label(f, :redirect_uris, gettext("Redirect URLs")) %>
    <%= textarea(f, :redirect_uris_text,
      rows: 3,
      name: "app[redirect_uris_text]",
      value: Enum.join(Ecto.Changeset.get_field(@changeset, :redirect_uris) || [], "\n")
    ) %>
    <p class="editform__hint">
      {gettext(
        "One per line. Exact https:// URLs (http://localhost is allowed for development). The authorization flow only ever redirects to these."
      )}
    </p>
    <%= error_tag(f, :redirect_uris) %>
  </div>

  <.form_actions backlink={@backlink} delete_to={assigns[:delete_to]} confirm={assigns[:confirm]} />
</.form>
