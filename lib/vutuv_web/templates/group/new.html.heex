<.page_header crumbs={[
  gettext("Users"),
  {full_name(@user), ~p"/#{@user}"},
  {gettext("Groups"), ~p"/#{@user}/groups"},
  gettext("New")
]} />

<.card_section>
  <%= render "form_content.html", backlink: ~p"/#{@user}/groups", changeset: @changeset, action: ~p"/#{@user}/groups" %>
</.card_section>
