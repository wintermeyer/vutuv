<div class="imagebox imagebox--welcome">
  <section class="card imagebox__card">
    <div class="imagebox__intro">
      <h1>Login</h1>
    </div>
    <.form :let={f} for={%{}} action={~p"/sessions"} as={:session} class="imagebox__form">
      <%= text_input f, :email, class: "imagebox__input", placeholder: gettext("Enter your email address"), autofocus: true %>
      <%= submit gettext("Log in"), class: "button button--block" %>
    </.form>
  </section>
</div>
