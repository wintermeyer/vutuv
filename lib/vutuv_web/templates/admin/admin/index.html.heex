<div class="profile-header">
  <div class="profile-header__info">
    <h1><%= gettext("Admin control panel") %></h1>
  </div>
</div>

<div class="breadcrumbs">
  <%= VutuvWeb.UserHelpers.gen_breadcrumbs([gettext("Admin")]) %>
</div>

<div class="card-list">
  {VutuvWeb.Admin.SlugHTML.index(%{conn: @conn})}
  {VutuvWeb.Admin.UserHTML.index(%{conn: @conn, users: @users})}
</div>
