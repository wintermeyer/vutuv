<.form :let={f} for={%{}} action={~p"/admin/slugs"} as={:slug_disable} multipart class="editform">

  <div class={"editform__field#{if error_tag(f, :value), do: " editform__field--error"}"}>
    <%= label f, :slug_name %>
    <%= text_input f, :value %>
    <%= error_tag f, :value %>
  </div>

    <%= submit gettext("Disable"), class: "button" %>
</.form>
