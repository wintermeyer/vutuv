  <div class="profile-header">
    <div class="profile-header__info">
      <h1><%= gettext("Emails belonging to ") %><%= full_name(@user) %></h1>
    </div>
  </div>

<div class="breadcrumbs">
  <%= gen_breadcrumbs([
    gettext("Users"),
    {full_name(@user), ~p"/users/#{@user}"},
    gettext("Emails")]) %>
</div>


<.card_section
  empty={Enum.empty?(@emails)}
  add_href={same_user?(@user, @current_user) && ~p"/users/#{@current_user}/emails/new"}
>
  <%= render "card_list.html", assigns %>
</.card_section>
