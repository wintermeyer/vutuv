<.form_page
  user={@user}
  active={:messengers}
  section={{gettext("Messengers"), ~p"/settings/messengers"}}
  title={gettext("Edit messenger")}
>
  <%= render "form_content.html", backlink: ~p"/settings/messengers", changeset: @changeset, action: ~p"/settings/messengers/#{@messenger}", delete_to: ~p"/settings/messengers/#{@messenger}" %>
</.form_page>
