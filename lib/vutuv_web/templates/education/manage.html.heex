<%!-- The owner's editor for this section — the user-agnostic /settings URL
(whoever opens it edits their own data). The public twin at /:slug/educations
shows the plain showcase view. --%>
<.settings_shell user={@user} active={:education} title={gettext("Education")}>
  <.card_section
    empty={Enum.empty?(@education)}
    add_href={~p"/settings/educations/new"}
    add_label={gettext("Add education")}
  >
    <%= render "card_list.html", assigns %>
  </.card_section>
</.settings_shell>
