<.page_header crumbs={[
  gettext("Users"),
  {full_name(@user), ~p"/#{@user}"},
  {gettext("Education"), ~p"/#{@user}/educations"},
  gettext("Edit")
]} />


<.card_section>
  <%= render "form_content.html", backlink: ~p"/#{@user}/educations", changeset: @changeset, action: ~p"/#{@user}/educations/#{@education}", delete_to: ~p"/#{@user}/educations/#{@education}", current_year: @current_year %>
</.card_section>
