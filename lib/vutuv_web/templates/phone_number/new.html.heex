<.page_header crumbs={[
  gettext("Users"),
  {full_name(@user), ~p"/#{@user}"},
  {gettext("Phone Numbers"), ~p"/#{@user}/phone_numbers"},
  gettext("New")
]} />

<.card_section>
  <%= render "form_content.html", backlink: ~p"/#{@user}/phone_numbers", changeset: @changeset, action: ~p"/#{@user}/phone_numbers" %>
</.card_section>
