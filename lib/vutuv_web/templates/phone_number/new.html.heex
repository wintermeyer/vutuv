
<div class="breadcrumbs">
  <%= gen_breadcrumbs([
    gettext("Users"),
    {full_name(@user), ~p"/users/#{@user}"},
    {gettext("Phone Numbers"), ~p"/users/#{@user}/phone_numbers"},
    gettext("New")]) %>
</div>

<div class="card-list">

  <section class="card">
    <%= render "form_content.html", backlink: ~p"/users/#{@user}/phone_numbers", changeset: @changeset, action: ~p"/users/#{@user}/phone_numbers" %>
  </section>
</div>
