<.page_header crumbs={[
  {gettext("Settings"), ~p"/#{@user}/settings"},
  {gettext("Phone Numbers"), ~p"/#{@user}/phone_numbers"},
  gettext("Edit")
]} />

<.card_section>
  <%= render "form_content.html", backlink: ~p"/#{@user}/phone_numbers", changeset: @changeset, action: ~p"/#{@user}/phone_numbers/#{@phone_number}", delete_to: ~p"/#{@user}/phone_numbers/#{@phone_number}" %>
</.card_section>
