<.page_header crumbs={[
  {gettext("Settings"), ~p"/settings"},
  {gettext("Phone Numbers"), ~p"/settings/phone_numbers"},
  gettext("Edit")
]} />

<.card_section>
  <%= render "form_content.html", backlink: ~p"/settings/phone_numbers", changeset: @changeset, action: ~p"/settings/phone_numbers/#{@phone_number}", delete_to: ~p"/settings/phone_numbers/#{@phone_number}" %>
</.card_section>
