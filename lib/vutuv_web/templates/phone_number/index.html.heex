<.page_header
  title={gettext("Phone Numbers Belonging to ") <> full_name(@user)}
  crumbs={[
    gettext("Users"),
    {full_name(@user), ~p"/users/#{@user}"},
    gettext("Phone Numbers")
  ]}
/>


<.card_section
  empty={Enum.empty?(@phone_numbers)}
  add_href={same_user?(@user, @current_user) && ~p"/users/#{@current_user}/phone_numbers/new"}
>
  <%= render "card_list.html", assigns %>
</.card_section>
