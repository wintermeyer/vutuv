<.form :let={f} for={@changeset} action={@action} class="search-form">
  <%= if @changeset.action do %>
    <div class="message message--failure">
      <p><%= gettext "Oops, something went wrong! Please check the errors below." %></p>
    </div>
  <% end %>
  <%= text_input f, :value, placeholder: gettext("Search here"), value: @conn.assigns[:value], autofocus: true %>
  <%= error_tag f, :value %>

  <%= submit gettext("Search"), class: "button search-submit" %>
</.form>
