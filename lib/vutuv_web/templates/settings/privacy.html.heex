<%!-- Privacy & visibility settings. Split off the old single edit form. The
checkboxes use the same inverted mechanism as the sign-up form: the field is
`noindex?` / `noai?` (an opt-OUT), but the box is framed positively ("Allow
…"), so checked submits "false" (allow) and unchecked submits "true". --%>
<div class="py-6">
  <h1 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">{gettext("Settings")}</h1>
  <.settings_nav user={@user} active={:privacy} class="mb-6" />

  <.card>
    <.section_title>{gettext("Privacy & visibility")}</.section_title>
    <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
      {gettext("Choose who may discover and reuse your public profile. You can change this any time.")}
    </p>

    <.form :let={f} for={@changeset} action={~p"/#{@user}/settings/privacy"} class="mt-5 space-y-5">
      <.form_error changeset={@changeset} />

      <label class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
        <%= checkbox f, :noindex?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %>
        <span>
          <span class="block font-medium text-slate-900 dark:text-white">
            {gettext("Allow search engines to index your profile")}
          </span>
          <span class="block">
            {gettext("When on, your public profile can appear in Google and other search engines.")}
          </span>
        </span>
      </label>

      <label class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
        <%= checkbox f, :noai?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %>
        <span>
          <span class="block font-medium text-slate-900 dark:text-white">
            {gettext("Allow AI agents and LLMs to use your profile")}
          </span>
          <span class="block">
            {gettext("When on, AI assistants and crawlers may read and train on your public profile.")}
          </span>
        </span>
      </label>

      <div class="pt-1">
        <.button type="submit">{gettext("Save")}</.button>
      </div>
    </.form>
  </.card>
</div>
