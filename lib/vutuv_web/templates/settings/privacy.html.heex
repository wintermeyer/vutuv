<%!-- Privacy: who can find, reuse, and reach you. Two cards:
"Search engines & AI" (the robot consents, the same inverted checkbox as the
sign-up form: the field is the opt-OUT noindex?/noai?, but the box reads
positively "Allow ...", so checked submits "false") and "Safety" (blocked
members + the moderation status), both moved here from the account hub where
members did not look for them. The helper line under each checkbox is forced
font-normal because the surrounding <label> defaults to bold (components.css),
which would otherwise render the hint heavier than its own heading. --%>
<.settings_shell user={@user} active={:privacy} title={gettext("Privacy")}>

  <div class="space-y-6">
    <.card>
      <.section_title>{gettext("Search engines & AI")}</.section_title>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
        {gettext("We can't stop a search engine or AI service from reading a page it can open. What we can do is tell them, in the machine-readable way they look for, that you don't want your profile listed in search results or used by AI. Reputable search engines and AI companies follow that request; we can't force the rest.")}
      </p>

      <%!-- Plain language above for everyone; the exact directives folded into a
      collapsed disclosure for the technical reader. An example beats prose, so
      show the real signals verbatim. Native <details>, no JS. The example is a
      plain string interpolated with {...} so HEEx escapes the angle brackets to
      text instead of parsing <meta> as an element. --%>
      <details class="group mt-2 text-sm text-slate-600 dark:text-slate-400">
        <summary class="inline-flex cursor-pointer items-center gap-1 font-medium text-slate-700 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
          <svg
            class="h-4 w-4 transition-transform group-open:rotate-90"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
          </svg>
          {gettext("Exactly what we send")}
        </summary>
        <div class="mt-2 space-y-2 pl-5">
          <p>{gettext("Turn a switch off and the matching opt-out rides along on the pages and responses about you. With both off, for example:")}</p>
          <% optout_example =
            ~s(<meta name="robots" content="noindex, noai, noimageai">) <>
              "\n\nX-Robots-Tag: noindex, noai, noimageai" <>
              "\nContent-Signal: ai-train=no, search=no, ai-input=no" %>
          <pre class="overflow-x-auto rounded-lg bg-slate-900 p-3 text-xs leading-relaxed text-slate-100 ring-1 ring-slate-800 dark:bg-slate-950"><code>{optout_example}</code></pre>
          <p class="text-xs">
            {gettext("Compliant crawlers honor these; they are not a hard block. A noindexed profile is also kept out of the sitemap and structured data.")}
          </p>
        </div>
      </details>

      <.form :let={f} for={@changeset} action={~p"/settings/privacy"} class="mt-5 space-y-5">
        <.form_error changeset={@changeset} />

        <.setting_toggle label={gettext("Allow search engines to index your profile")}>
          <:checkbox><%= checkbox f, :noindex?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %></:checkbox>
          {gettext("When on, your public profile can appear in Google and other search engines. When off, we ask them to leave it out.")}
        </.setting_toggle>

        <.setting_toggle label={gettext("Allow AI agents and LLMs to use your profile")}>
          <:checkbox><%= checkbox f, :noai?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %></:checkbox>
          {gettext("When on, AI assistants and crawlers may read and train on your public profile. When off, we ask them not to.")}
        </.setting_toggle>

        <div class="pt-1">
          <.button type="submit">{gettext("Save")}</.button>
        </div>
      </.form>
    </.card>

    <%!-- Online status: the real-time green dot on your avatar. A positive flag
          (checked = shown), so a plain checkbox, unlike the inverted opt-out
          robot switches above. Off means VutuvWeb.Presence never tracks you, so
          you appear online to no one (not even on your own top-bar avatar). --%>
    <.toggle_form_card
      changeset={@changeset}
      field={:show_online_status?}
      form_id="online-status-form"
      title={gettext("Online status")}
      intro={gettext("A green dot on your avatar tells other members you are online right now.")}
      label={gettext("Show when I'm online")}
      hint={gettext("When off, no one sees the green dot on your avatar, and you never show as online.")}
    />

    <%!-- Social media posts: the inline feed card on the profile
          (Vutuv.SocialFeed, Mastodon + Bluesky). A positive flag like the
          online dot above: default on, so a listed account shows its latest
          public posts until the member opts out here. The column keeps its
          historical name (show_mastodon_feed?) but gates the whole card. --%>
    <.toggle_form_card
      changeset={@changeset}
      field={:show_mastodon_feed?}
      form_id="social-feed-form"
      title={gettext("Social media posts")}
      intro={
        gettext(
          "If you list a Mastodon or Bluesky account, your profile can show your latest public posts from it."
        )
      }
      label={gettext("Show my latest social media posts on my profile")}
      hint={gettext("When off, the Social Media card lists your accounts without any posts.")}
    />

    <%!-- Code statistics: the profile's "Code" card (Vutuv.CodeStats, GitHub +
          GitLab + Codeberg). Same positive-flag pattern as the posts card
          above: default on, a listed forge account shows its public stats
          until the member opts out here. --%>
    <.toggle_form_card
      changeset={@changeset}
      field={:show_code_stats?}
      form_id="code-stats-form"
      title={gettext("Code statistics")}
      intro={
        gettext(
          "If you list a GitHub, GitLab or Codeberg account, your profile can show its public statistics: stars, repositories, followers, languages and recent activity."
        )
      }
      label={gettext("Show code statistics on my profile")}
      hint={gettext("When off, the Social Media card lists your accounts as plain links only.")}
    />

    <%!-- Safety: the two things you reach for when someone is a problem or your
          content is being looked at. Grouped in one card (two rows) so neither
          reads as a lonely one-line card. --%>
    <.card>
      <.section_title>{gettext("Safety")}</.section_title>
      <ul class="mt-2 divide-y divide-slate-100 dark:divide-slate-800">
        <.account_row
          title={gettext("Blocked members")}
          subtitle={gettext("People who cannot interact with you.")}
          href={~p"/blocks"}
          label={gettext("Manage")}
        />
        <.account_row
          title={gettext("Content under review")}
          subtitle={gettext("Your posts or profile a moderator is looking at.")}
          href={~p"/moderation/cases"}
          label={gettext("View")}
        />
      </ul>
    </.card>
  </div>
</.settings_shell>
