
<div class="breadcrumbs">
  <%= gen_breadcrumbs([
    gettext("Users"), 
    {full_name(@user), ~p"/users/#{@user}"},
    {gettext("Experience"), ~p"/users/#{@user}/work_experiences"},
    gettext("New")]) %>
</div>


<div class="card-list">

  <section class="card">

  <%= render "form_content.html", backlink: ~p"/users/#{@user}/work_experiences", changeset: @changeset, action: ~p"/users/#{@user}/work_experiences", current_year: @current_year %>
  </section>
</div>
