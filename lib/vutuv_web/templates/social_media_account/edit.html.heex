
<div class="breadcrumbs">
  <%= gen_breadcrumbs([
    gettext("Users"),
    {full_name(@user), ~p"/users/#{@user}"},
    {gettext("Social Media Accounts"), ~p"/users/#{@user}/social_media_accounts"},
    gettext("Edit")]) %>
</div>

<div class="card-list">

  <section class="card">
    <%= render "form_content.html", backlink: ~p"/users/#{@user}/social_media_accounts", changeset: @changeset, action: ~p"/users/#{@user}/social_media_accounts/#{@social_media_account}" %>
  </section>
</div>
