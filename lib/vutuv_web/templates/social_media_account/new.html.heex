
<div class="breadcrumbs">
  <%= gen_breadcrumbs([
    gettext("Users"),
    {full_name(@user), ~p"/users/#{@user}"},
    {gettext("Social Media Accounts"), ~p"/users/#{@user}/social_media_accounts"},
    gettext("New")]) %>
</div>

<.card_section>
  <%= render "form_content.html", backlink: ~p"/users/#{@user}/social_media_accounts", changeset: @changeset, action: ~p"/users/#{@user}/social_media_accounts" %>
</.card_section>
