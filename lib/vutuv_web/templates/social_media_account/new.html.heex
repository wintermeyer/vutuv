<.page_header crumbs={[
  gettext("Users"),
  {full_name(@user), ~p"/#{@user}"},
  {gettext("Social Media Accounts"), ~p"/#{@user}/social_media_accounts"},
  gettext("New")
]} />

<.card_section>
  <%= render "form_content.html", backlink: ~p"/#{@user}/social_media_accounts", changeset: @changeset, action: ~p"/#{@user}/social_media_accounts" %>
</.card_section>
