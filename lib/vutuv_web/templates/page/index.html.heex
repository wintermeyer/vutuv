<.auth_layout title={gettext("“Tired of LinkedIn, Facebook, or X? Same here. Welcome aboard!”")}>
  <:headline>
    <% founder_quote_main = gettext("“Tired of LinkedIn, Facebook, or X? Same here.") %>
    <% founder_welcome = gettext("Welcome aboard!”") %>
    <% founder_name = "Stefan Wintermeyer" %>
    <% founder_role = gettext("Founder of vutuv") %>
    <%!-- Founder hero: the whole quote in one heading at a single size (setup
          and "Welcome aboard!" flow together), then a right-aligned signature
          with the name above the role, set snug. The member-count pill below
          is shared from the :hero slot. --%>
    <div>
      <h1 class="text-2xl font-bold leading-tight md:text-3xl">
        {founder_quote_main} {founder_welcome}
      </h1>
      <div class="mt-6 text-right">
        <p class="font-serif text-2xl leading-none text-white">
          <a
            href="https://vutuv.de/wintermeyer"
            class="text-white underline decoration-brand-200 underline-offset-4 hover:decoration-white"
          >
            {founder_name}
          </a>
        </p>
        <p class="-mt-2 text-sm text-brand-100">{founder_role}</p>
      </div>
    </div>
  </:headline>
  <:hero>
    {live_render(@conn, VutuvWeb.MemberCountLive, id: "member-count-lv")}
  </:hero>

  <h2 class="text-xl font-bold text-slate-900 dark:text-white">
    {gettext("Create your free account")}
  </h2>

  <.form
    :let={f}
    for={@changeset}
    action={~p"/new_registration"}
    multipart
    class="mt-5 space-y-4"
    id="registration-form"
  >
    <.form_error changeset={@changeset} />

    <%!-- A radio group, not a dropdown: all options are visible and "männlich"
          is preselected (set on the changeset by the controller), so a normal
          user is not left on an empty "Geschlecht auswählen" prompt. --%>
    <fieldset>
      <legend class="mb-1.5 text-sm font-semibold text-slate-700 dark:text-slate-300">
        {gettext("Gender")}
      </legend>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        <%= for {label, value} <- [{gettext("male"), "male"}, {gettext("female"), "female"}, {gettext("other"), "other"}] do %>
          <label class="flex items-center gap-2 text-sm font-normal text-slate-700 dark:text-slate-200">
            <%= radio_button f, :gender, value, class: "h-4 w-4 border-slate-300 text-brand-600 focus:ring-brand-500 dark:border-slate-600 dark:bg-slate-800", autofocus: value == "male" %>
            <span>{label}</span>
          </label>
        <% end %>
      </div>
      <%= error_tag f, :gender %>
    </fieldset>

    <div>
      <%= text_input f, :first_name, class: input_class(), placeholder: gettext("Enter your first name") %>
      <%= error_tag f, :first_name %>
    </div>

    <div>
      <%= text_input f, :last_name, class: input_class(), placeholder: gettext("Enter your last name") %>
      <%= error_tag f, :last_name %>
    </div>

    <div>
      <%= text_input f, :tag_list, class: input_class(), placeholder: gettext("Your tags (e.g. JavaScript, Cooking, Origami, Cat)") %>
      <%= error_tag f, :tag_list %>
    </div>

    <.inputs_for :let={ef} field={f[:emails]}>
      <%!-- The email-type choice comes first (above the address field): a
            radio group, not a dropdown, so a normal user sees all three
            choices at once, and "Work" is preselected (set on the changeset by
            the controller) instead of the old unhelpful "Other" default. --%>
      <fieldset>
        <legend class="mb-1.5 text-sm font-semibold text-slate-700 dark:text-slate-300">
          {gettext("Type of email address")}
        </legend>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <%= for {label, value} <- [{gettext("Work"), "Work"}, {gettext("Personal"), "Personal"}, {gettext("Other"), "Other"}] do %>
            <label class="flex items-center gap-2 text-sm font-normal text-slate-700 dark:text-slate-200">
              <%= radio_button ef, :email_type, value, class: "h-4 w-4 border-slate-300 text-brand-600 focus:ring-brand-500 dark:border-slate-600 dark:bg-slate-800" %>
              <span>{label}</span>
            </label>
          <% end %>
        </div>
        <%= error_tag ef, :email_type %>
      </fieldset>

      <div>
        <%= email_input ef, :value, class: input_class(), placeholder: gettext("Enter your email address") %>
        <%= error_tag ef, :value %>
      </div>

      <%!-- Checked by default (the controller primes public?: true on the
            changeset), so a normal member's address shows on their profile
            unless they opt out here. --%>
      <label class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300">
        <%= checkbox ef, :public?, class: checkbox_class() %>
        <span>{gettext("Allow others to view your email address")}</span>
        <%= error_tag ef, :public? %>
      </label>
    </.inputs_for>

    <%!-- Positive, opt-in phrasing to match the email checkbox above, and
          checked by default. The field is `noindex?`, so the box is inverted:
          checked submits "false" (allow indexing), unchecked submits "true". --%>
    <label class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300">
      <%= checkbox f, :noindex?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %>
      <%!-- The "(SEO)" / "(GEO)" tags are international (same in DE/EN), so they
            are literal text outside gettext rather than part of the string. --%>
      <span>{gettext("Allow search engines to index your profile")} (SEO)</span>
      <%= error_tag f, :noindex? %>
    </label>

    <%!-- The AI question, asked separately (a member may say yes to search
          engines and no to AI, or the other way around). Same inverted
          mechanism on `noai?`: checked submits "false" (allow AI use). --%>
    <label class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300">
      <%= checkbox f, :noai?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %>
      <span>{gettext("Allow AI agents and LLMs to use your profile")} (GEO)</span>
      <%= error_tag f, :noai? %>
    </label>

    <.button type="submit" class="w-full">{gettext("Sign up for a free account")}</.button>

    <%!-- Consent / information notice. The Datenschutzerklärung is information we
          must surface (GDPR Art. 13), not a separate consent checkbox, so a
          linked one-liner by the button is enough. The sentence is one gettext
          string with a {datenschutz} placeholder we split on, so the link sits
          mid-sentence in German and at the end in English without two
          half-sentence fragments. --%>
    <% [policy_pre, policy_post] =
      String.split(
        gettext("By creating an account you confirm that you have read our {datenschutz}."),
        "{datenschutz}"
      ) %>
    <p class="text-center text-xs text-slate-600 dark:text-slate-400">
      {policy_pre}<a href={~p"/datenschutzerklaerung"} class="font-semibold text-brand-600 hover:text-brand-700">{gettext("Datenschutzerklärung")}</a>{policy_post}
    </p>

    <p class="text-center text-sm">
      <a href={~p"/login"} class="font-semibold text-brand-600 hover:text-brand-700">{gettext("Already a member? Sign in here.")}</a>
    </p>

    <p class="text-xs text-slate-600 dark:text-slate-400">{gettext("We reserve the right to stop this service or delete your account anytime without warning.")}</p>
  </.form>
</.auth_layout>

<JsonLd.script data={JsonLd.organization()} />
<JsonLd.script data={JsonLd.web_site()} />
