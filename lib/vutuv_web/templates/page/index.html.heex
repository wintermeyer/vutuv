<.auth_layout title={gettext("“Tired of LinkedIn, Facebook, or X? Same here. Welcome aboard!”")}>
  <:headline>
    <% founder_quote_main = gettext("“Tired of LinkedIn, Facebook, or X? Same here.") %>
    <% founder_welcome = gettext("Welcome aboard!”") %>
    <% founder_name = "Stefan Wintermeyer" %>
    <% founder_role = gettext("Founder of vutuv") %>
    <%!-- Founder hero: the whole quote in one heading at a single size (setup
          and "Welcome aboard!" flow together), then a right-aligned signature
          with the name above the role, set snug. The member-count pill below
          is shared from the :hero slot. --%>
    <div>
      <h1 class="text-2xl font-bold leading-tight md:text-3xl">
        {founder_quote_main} {founder_welcome}
      </h1>
      <div class="mt-6 text-right">
        <p class="font-serif text-2xl leading-none text-white">
          <a
            href="https://vutuv.de/wintermeyer"
            class="text-white underline decoration-brand-200 underline-offset-4 hover:decoration-white"
          >
            {founder_name}
          </a>
        </p>
        <p class="-mt-2 text-sm text-brand-100">{founder_role}</p>
      </div>
    </div>
  </:headline>
  <:hero>
    {live_render(@conn, VutuvWeb.MemberCountLive, id: "member-count-lv")}
  </:hero>

  <h2 class="text-xl font-bold text-slate-900 dark:text-white">
    {gettext("Create your free account")}
  </h2>

  <%!-- The sign-up form is grouped into three blocks (who you are / your email
        / privacy) divided by hairlines, so the fields read as three digestible
        sections instead of one long, undifferentiated list. Shared class/option
        bindings keep the repeated radio groups and consent checkboxes
        consistent. --%>
  <% gender_options = [{gettext("male"), "male"}, {gettext("female"), "female"}, {gettext("other"), "other"}] %>
  <% email_type_options = [{gettext("Work"), "Work"}, {gettext("Personal"), "Personal"}, {gettext("Other"), "Other"}] %>
  <% radio_class = "h-4 w-4 border-slate-300 text-brand-600 focus:ring-brand-500 dark:border-slate-600 dark:bg-slate-800" %>
  <% legend_class = "mb-1.5 text-sm font-semibold text-slate-700 dark:text-slate-300" %>
  <% radio_label_class = "flex items-center gap-2 text-sm font-normal text-slate-700 dark:text-slate-200" %>
  <% check_label_class = "flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300" %>

  <.form
    :let={f}
    for={@changeset}
    action={~p"/new_registration"}
    multipart
    class="mt-5 space-y-6"
    id="registration-form"
  >
    <.form_error changeset={@changeset} />

    <%!-- Group 1: who you are. A radio group, not a dropdown: all options are
          visible and "männlich" is preselected (set on the changeset by the
          controller), so a normal user is not left on an empty
          "Geschlecht auswählen" prompt. --%>
    <div class="space-y-4">
      <fieldset>
        <legend class={legend_class}>{gettext("Gender")}</legend>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <%= for {glabel, gvalue} <- gender_options do %>
            <label class={radio_label_class}>
              <%= radio_button f, :gender, gvalue, class: radio_class, autofocus: gvalue == "male" %>
              <span>{glabel}</span>
            </label>
          <% end %>
        </div>
        <%= error_tag f, :gender %>
      </fieldset>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= text_input f, :first_name, class: input_class(f, :first_name), placeholder: gettext("Enter your first name"), "aria-invalid": f.errors[:first_name] && "true" %>
          <%= error_tag f, :first_name %>
        </div>
        <div>
          <%= text_input f, :last_name, class: input_class(f, :last_name), placeholder: gettext("Enter your last name"), "aria-invalid": f.errors[:last_name] && "true" %>
          <%= error_tag f, :last_name %>
        </div>
      </div>
      <div>
        <%= text_input f, :tag_list, class: input_class(f, :tag_list), placeholder: gettext("Your tags (e.g. JavaScript, Cooking, Origami, Cat)"), "aria-invalid": f.errors[:tag_list] && "true" %>
        <%!-- Tags are how members are found, so sign-up asks for at least
              three (enforced by the registration changeset). On a failed
              submit the specific error replaces the hint — the two would say
              nearly the same thing, and one clear line beats a red-on-grey
              stack. The input itself turns red via input_class/2. --%>
        <%= error_tag f, :tag_list %>
        <p :if={!f.errors[:tag_list]} class="mt-1 text-sm text-slate-600 dark:text-slate-400">{gettext("At least three tags, separated by a comma or a space.")}</p>
      </div>
    </div>

    <%!-- Group 2: email. The email-type choice comes first (above the address
          field): a radio group, not a dropdown, so a normal user sees all three
          choices at once, and "Work" is preselected (set on the changeset by
          the controller) instead of the old unhelpful "Other" default. --%>
    <div class="space-y-4 border-t border-slate-200 pt-6 dark:border-slate-800">
      <.inputs_for :let={ef} field={f[:emails]}>
        <fieldset>
          <legend class={legend_class}>{gettext("Type of email address")}</legend>
          <div class="flex flex-wrap gap-x-5 gap-y-2">
            <%= for {elabel, evalue} <- email_type_options do %>
              <label class={radio_label_class}>
                <%= radio_button ef, :email_type, evalue, class: radio_class %>
                <span>{elabel}</span>
              </label>
            <% end %>
          </div>
          <%= error_tag ef, :email_type %>
        </fieldset>
        <div>
          <%= email_input ef, :value, class: input_class(ef, :value), placeholder: gettext("Enter your email address"), "aria-invalid": ef.errors[:value] && "true" %>
          <%= error_tag ef, :value %>
        </div>
        <%!-- Checked by default (the controller primes public?: true on the
              changeset), so a normal member's address shows on their profile
              unless they opt out here. --%>
        <label class={check_label_class}>
          <%= checkbox ef, :public?, class: checkbox_class() %>
          <span>{gettext("Allow others to view your email address")}</span>
          <%= error_tag ef, :public? %>
        </label>
      </.inputs_for>
    </div>

    <%!-- Group 3: privacy. Positive, opt-in phrasing to match the email
          checkbox above, and checked by default. Both fields are inverted:
          the box reads positively ("Allow ...") while the underlying
          `noindex?` / `noai?` flags are negative, so a checked box submits
          "false" (allow). The SEO question (search engines) and the GEO
          question (AI agents / LLMs) are asked separately, since a member may
          say yes to one and no to the other. --%>
    <div class="space-y-3 border-t border-slate-200 pt-6 dark:border-slate-800">
      <label class={check_label_class}>
        <%= checkbox f, :noindex?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %>
        <%!-- The "(SEO)" / "(GEO)" tags are international (same in DE/EN), so they
              are literal text outside gettext rather than part of the string. --%>
        <span>{gettext("Allow search engines to index your profile")} (SEO)</span>
        <%= error_tag f, :noindex? %>
      </label>
      <label class={check_label_class}>
        <%= checkbox f, :noai?, checked_value: "false", unchecked_value: "true", class: checkbox_class() %>
        <span>{gettext("Allow AI agents and LLMs to use your profile")} (GEO)</span>
        <%= error_tag f, :noai? %>
      </label>
    </div>

    <.button type="submit" class="w-full">{gettext("Sign up for a free account")}</.button>

    <%!-- Consent / information notice by the button. Accepting the
          Nutzungsbedingungen at sign-up is what incorporates the AGB into the
          contract (§305 BGB); the Datenschutzerklärung is information we must
          surface (GDPR Art. 13), not a consent. The sentence is one gettext
          string with two ordered placeholders we split on, so both links sit
          in their natural place in German and English alike. --%>
    <% [nb_pre, nb_rest] =
      String.split(
        gettext(
          "By creating an account you accept our {nutzungsbedingungen} and confirm that you have read our {datenschutz}."
        ),
        "{nutzungsbedingungen}"
      ) %>
    <% [ds_mid, ds_post] = String.split(nb_rest, "{datenschutz}") %>
    <p class="text-center text-xs text-slate-600 dark:text-slate-400">
      {nb_pre}<a href={~p"/nutzungsbedingungen"} class="font-semibold text-brand-600 hover:text-brand-700">{gettext("Nutzungsbedingungen")}</a>{ds_mid}<a href={~p"/datenschutzerklaerung"} class="font-semibold text-brand-600 hover:text-brand-700">{gettext("Datenschutzerklärung")}</a>{ds_post}
    </p>

    <p class="text-center text-sm">
      <a href={~p"/login"} class="font-semibold text-brand-600 hover:text-brand-700">{gettext("Already a member? Sign in here.")}</a>
    </p>

    <p class="text-xs text-slate-600 dark:text-slate-400">{gettext("We reserve the right to stop this service or delete your account anytime without warning.")}</p>
  </.form>
</.auth_layout>

<JsonLd.script data={JsonLd.organization()} />
<JsonLd.script data={JsonLd.web_site()} />
